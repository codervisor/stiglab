{
  "name": "stiglab",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,ui -c blue,cyan \"pnpm dev:server\" \"pnpm dev:ui\"",
    "dev:server": "cargo run -p stiglab -- server",
    "dev:server:no-runner": "cargo run -p stiglab -- server --no-runner",
    "dev:agent": "cargo run -p stiglab -- agent --server ws://localhost:3000/agent/ws --name dev-node",
    "dev:ui": "pnpm --filter stiglab-ui dev",
    "build": "cargo build --release -p stiglab && pnpm --filter stiglab-ui build",
    "build:ui": "pnpm --filter stiglab-ui build",
    "lint": "cargo fmt --all -- --check && cargo clippy --all-targets -- -D warnings && pnpm --filter stiglab-ui lint",
    "test": "cargo test --all && pnpm --filter stiglab-ui test",
    "test:ui": "pnpm --filter stiglab-ui test",
    "test:e2e": "pnpm --filter stiglab-ui test:e2e",
    "test:e2e:smoke": "pnpm --filter stiglab-ui test:e2e:smoke",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "agent-browser",
      "msw"
    ]
  }
}
